# SkinGraph backend environment. Copy to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# --- Required ---------------------------------------------------------------
# Google AI (Gemini) API key — powers the scanner, web-search, and coach nodes.
GOOGLE_API_KEY=your_key_here

# --- Observability (LangSmith) — optional but recommended -------------------
# When LANGCHAIN_TRACING_V2=true AND LANGCHAIN_API_KEY is set, LangGraph and the
# Gemini chat models auto-report every run to LangSmith. No code change needed.
# (The newer LANGSMITH_* names work too — the SDK reads either prefix.)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_key_here
LANGCHAIN_PROJECT=skincare-architect-v1
# Skincare labels (base64 images) and ingredient lists can be sensitive — keep
# request payloads out of the trace. Set HIDE_OUTPUTS too to also drop results.
LANGCHAIN_HIDE_INPUTS=true
# LANGCHAIN_HIDE_OUTPUTS=true

# --- API (optional) ---------------------------------------------------------
# Comma-separated browser origins allowed to call the API (CORS).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
