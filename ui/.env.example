# Base URL of the SkinGraph FastAPI backend.
# Local dev (uvicorn / docker-compose):
VITE_API_BASE_URL=http://localhost:8000

# Live backend (Railway public URL):
# VITE_API_BASE_URL=https://your-app.up.railway.app
#
# AWS reference stack (ALB endpoint from `terraform output api_endpoint`):
# VITE_API_BASE_URL=http://skincare-coach-xxxxx.us-east-1.elb.amazonaws.com
